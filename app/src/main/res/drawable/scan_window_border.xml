<?xml version="1.0" encoding="utf-8"?>
<!-- Scan window: subtle inner border, corners highlighted separately in code via CornerDrawable -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Faint full border -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#2200E5FF" />
            <corners android:radius="6dp" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <!-- Brighter corner-only stroke (top-left inset) -->
    <item
        android:top="0dp"
        android:left="0dp"
        android:right="220dp"
        android:bottom="120dp">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#FF00E5FF" />
            <corners android:topLeftRadius="6dp" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <!-- top-right -->
    <item
        android:top="0dp"
        android:left="220dp"
        android:right="0dp"
        android:bottom="120dp">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#FF00E5FF" />
            <corners android:topRightRadius="6dp" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <!-- bottom-left -->
    <item
        android:top="120dp"
        android:left="0dp"
        android:right="220dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#FF00E5FF" />
            <corners android:bottomLeftRadius="6dp" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <!-- bottom-right -->
    <item
        android:top="120dp"
        android:left="220dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#FF00E5FF" />
            <corners android:bottomRightRadius="6dp" />
            <solid android:color="#00000000" />
        </shape>
    </item>
</layer-list>