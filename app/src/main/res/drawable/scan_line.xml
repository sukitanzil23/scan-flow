<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow shadow underneath -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#0000E5FF"
                android:centerColor="#5500E5FF"
                android:endColor="#0000E5FF" />
            <size android:height="4dp" />
        </shape>
    </item>
    <!-- Sharp neon line on top -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#0000E5FF"
                android:centerColor="#FF00E5FF"
                android:endColor="#0000E5FF" />
            <size android:height="2dp" />
        </shape>
    </item>
</layer-list>