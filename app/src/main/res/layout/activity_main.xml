<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Decorative top glow -->
    <View
        android:id="@+id/topGlow"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:alpha="0.07"
        android:background="@drawable/bg_glow_circle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-80dp" />

    <!-- Main content, vertically centered -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- App icon with glowing ring -->
        <FrameLayout
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_gravity="center">

            <!-- Outer glow ring -->
            <View
                android:layout_width="128dp"
                android:layout_height="128dp"
                android:background="@drawable/bg_icon_glow"
                android:alpha="0.35" />

            <!-- Icon card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ivAppIcon"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                app:cardCornerRadius="50dp"
                app:cardElevation="16dp"
                app:cardBackgroundColor="@color/surface_elevated"
                app:strokeColor="@color/primary"
                app:strokeWidth="1.5dp">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_camera"
                    android:tint="@color/primary"
                    android:contentDescription="@string/app_name" />

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

        <!-- App name -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/app_name"
            android:textSize="42sp"
            android:textStyle="bold"
            android:textColor="@color/on_background"
            android:letterSpacing="0.04" />

        <!-- Cyan accent underline -->
        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_accent_line" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/app_subtitle"
            android:textSize="15sp"
            android:textColor="@color/on_background_secondary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5" />

        <!-- Feature pills row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center"
            android:layout_marginTop="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Real-time"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:background="@drawable/bg_country_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="ML Kit"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:background="@drawable/bg_country_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="International"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:background="@drawable/bg_country_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

        <!-- CTA button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartScan"
            android:layout_width="240dp"
            android:layout_height="58dp"
            android:layout_marginTop="48dp"
            android:text="@string/start_scanning"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_primary"
            app:cornerRadius="29dp"
            app:icon="@drawable/ic_camera"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@color/text_on_primary"
            app:backgroundTint="@color/primary"
            android:stateListAnimator="@null"
            android:elevation="8dp" />

    </LinearLayout>

    <!-- Version label pinned to bottom -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>