<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_number_card"
    android:paddingStart="14dp"
    android:paddingEnd="10dp"
    android:paddingTop="13dp"
    android:paddingBottom="13dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Phone icon -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/iconContainer"
        android:layout_width="36dp"
        android:layout_height="36dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/badge_background"
        app:strokeColor="#2200E5FF"
        app:strokeWidth="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_phone"
            android:tint="@color/primary"
            android:contentDescription="Phone" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Number text -->
    <TextView
        android:id="@+id/tvPhoneNumber"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:ellipsize="end"
        android:maxLines="1"
        app:layout_constraintStart_toEndOf="@id/iconContainer"
        app:layout_constraintEnd_toStartOf="@id/tvCountryCode"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Country code badge -->
    <TextView
        android:id="@+id/tvCountryCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="6dp"
        android:background="@drawable/bg_country_badge"
        android:paddingStart="9dp"
        android:paddingEnd="9dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:textColor="@color/primary"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        app:layout_constraintEnd_toStartOf="@id/btnCopy"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Copy button -->
    <ImageButton
        android:id="@+id/btnCopy"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_copy"
        android:tint="@color/primary"
        android:contentDescription="Copy"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
